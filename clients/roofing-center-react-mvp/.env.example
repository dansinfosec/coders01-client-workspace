# Roofing Center — example environment variables (no real secrets here).
# The current demo works fully WITHOUT any of these (LocalDemoAdapter).
# Never call OpenAI (or any LLM) directly from the browser and never put a real
# API key in this frontend — all AI/lead handling must go through a backend.

# Base URL of a future backend (e.g. Django REST API)
VITE_API_BASE_URL=

# Endpoint that receives lead submissions (quote form + assistant)
VITE_LEAD_ENDPOINT=

# Optional n8n webhook for lead notifications / automation
VITE_N8N_WEBHOOK_URL=
