# All-in Daktechniek — voorbeeld-omgevingsvariabelen (geen echte secrets hier).
# De demo werkt volledig ZONDER deze waarden (formulier logt lokaal).
# Roep nooit een LLM of externe API rechtstreeks vanuit de browser aan en zet
# nooit een echte API-key in deze frontend — lead-afhandeling hoort achter een backend.

# Basis-URL van een toekomstige backend (bijv. een REST API)
VITE_API_BASE_URL=

# Endpoint dat offerte-/contactaanvragen ontvangt
VITE_LEAD_ENDPOINT=
